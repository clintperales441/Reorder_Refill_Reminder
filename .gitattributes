# Normalize text files and keep LF in repository/worktree.
* text=auto eol=lf

# Windows scripts keep CRLF when needed.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.pdf binary
*.zip binary
*.jar binary
*.db binary
